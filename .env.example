DATABASE_URL=postgresql://user:password@host.neon.tech/database?sslmode=require
DATABASE_SSL=true

# One worker process = one ACCOUNT_ID. For several numbers, set ACCOUNT_IDS to a
# comma-separated list (each gets its own QR + socket). ACCOUNT_IDS wins if both set.
ACCOUNT_ID=client-main
# ACCOUNT_IDS=client-main,client-2

API_PORT=3000

# Redis — BullMQ media queue + live-update pub/sub. docker compose runs one locally.
REDIS_URL=redis://localhost:6379

# API security / auth
API_JWT_ACCESS_SECRET=change-me-at-least-64-chars
API_JWT_REFRESH_SECRET=change-me-at-least-64-chars
ACCESS_TOKEN_COOKIE_NAME=wa_access
REFRESH_TOKEN_COOKIE_NAME=wa_refresh
CSRF_TOKEN_COOKIE_NAME=wa_csrf
API_ACCESS_TOKEN_TTL_SECONDS=900
API_REFRESH_TOKEN_TTL_SECONDS=2592000
LOGIN_RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# Optional legacy fallback (supported for now, but prefer JWT_*_* vars above)
API_SESSION_SECRET=change-me-at-least-64-chars

# Optional backup automation settings
BACKUP_DIR=./backups
BACKUP_RETENTION_DAYS=14

# Cloudflare R2 (media storage). Leave blank to run the pipeline without storing:
# media is parked as storage_status='pending' until these are set, then run
# `pnpm worker:backfill-media` to drain the backlog. See docs / the Phase 2 plan
# for how to obtain these from the Cloudflare dashboard.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
